# Google Chat Bot
GOOGLE_PROJECT_ID=
GOOGLE_CHAT_SERVICE_ACCOUNT_KEY=./config/service-account.json

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/chat_assistant

# Claude API
ANTHROPIC_API_KEY=

# Notion (one-way sync: PG → Notion)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Server
PORT=8080
